# ──────────────────────────────────────────────────────────────
# W·52 — Networking Memory App  |  шаблон переменных окружения
# Скопируй в .env и заполни реальными значениями
# .env НЕ попадает в Git (см. .gitignore)
# ──────────────────────────────────────────────────────────────

# Telegram Bot API токен (получить у @BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# Секрет для верификации Telegram webhook-запросов
# Любая случайная строка 32+ символов
TELEGRAM_WEBHOOK_SECRET=

# Anthropic API ключ для Claude AI (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# HuggingFace токен для Whisper-транскрипции (https://huggingface.co/settings/tokens)
HUGGINGFACE_TOKEN=

# Redis URL для хранения задач, голосовых заметок и регистраций
# Формат: redis://default:<password>@<host>:<port>
REDIS_URL=

# Публичный URL задеплоенного приложения (без слэша в конце)
APP_URL=https://w52-app.vercel.app

# Секрет для Vercel Cron jobs (автоматически проставляется Vercel)
CRON_SECRET=
