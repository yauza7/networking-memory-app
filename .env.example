# ──────────────────────────────────────────────
# W·52 — Networking Memory App
# Copy this file to `.env` and fill real values
# ──────────────────────────────────────────────

# Anthropic API key — server-side only (proxied by vite, never bundled)
# Get it at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Telegram bot token — used by the webhook on Vercel
# Get it from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=

# Secret used to verify Telegram webhook requests
# Generate a random 32+ char string and pass it to setWebhook?secret_token=...
TELEGRAM_WEBHOOK_SECRET=

# Public URL of the deployed Mini App (no trailing slash)
APP_URL=https://w52-app.vercel.app
